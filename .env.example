# Grafana container image/version
GRAFANA_IMAGE=grafana-oss
GRAFANA_VERSION=12.3.2

# Optional debug mode for Grafana Docker image
DEVELOPMENT=false
ANONYMOUS_AUTH_ENABLED=true

# Sigil service defaults
SIGIL_HTTP_ADDR=:8080
# Generation ingest gRPC endpoint (custom contract, not OTLP trace ingest)
SIGIL_OTLP_GRPC_ADDR=:4317
SIGIL_TARGET=all
SIGIL_AUTH_ENABLED=false
SIGIL_FAKE_TENANT_ID=fake
SIGIL_QUERY_PROXY_PROMETHEUS_BASE_URL=http://prometheus:9090
SIGIL_QUERY_PROXY_TEMPO_BASE_URL=http://tempo:3200
SIGIL_QUERY_PROXY_TIMEOUT=30s
SIGIL_STORAGE_BACKEND=mysql
SIGIL_MYSQL_DSN=sigil:sigil@tcp(mysql:3306)/sigil?parseTime=true
SIGIL_OBJECT_STORE_BACKEND=s3
SIGIL_OBJECT_STORE_ENDPOINT=http://minio:9000
SIGIL_OBJECT_STORE_BUCKET=sigil
SIGIL_OBJECT_STORE_ACCESS_KEY=minioadmin
SIGIL_OBJECT_STORE_SECRET_KEY=minioadmin
SIGIL_OBJECT_STORE_INSECURE=true
# Optional object store settings for cloud providers:
# SIGIL_OBJECT_STORE_S3_AWS_SDK_AUTH=true
# SIGIL_OBJECT_STORE_S3_REGION=us-east-1
# SIGIL_OBJECT_STORE_GCS_BUCKET=sigil-gcs
# SIGIL_OBJECT_STORE_GCS_SERVICE_ACCOUNT={"type":"service_account",...}
# SIGIL_OBJECT_STORE_AZURE_CONTAINER=sigil
# SIGIL_OBJECT_STORE_AZURE_STORAGE_ACCOUNT=<account>
# SIGIL_OBJECT_STORE_AZURE_STORAGE_ACCOUNT_KEY=<key>
# SIGIL_OBJECT_STORE_AZURE_STORAGE_CONNECTION_STRING=<connection-string>
# SIGIL_OBJECT_STORE_AZURE_ENDPOINT=blob.core.windows.net
# SIGIL_OBJECT_STORE_AZURE_CREATE_CONTAINER=true
SIGIL_COMPACTOR_COMPACT_INTERVAL=1m
SIGIL_COMPACTOR_TRUNCATE_INTERVAL=5m
SIGIL_COMPACTOR_RETENTION=1h
SIGIL_COMPACTOR_BATCH_SIZE=1000
SIGIL_COMPACTOR_LEASE_TTL=30s
SIGIL_COMPACTOR_SHARD_COUNT=8
SIGIL_COMPACTOR_SHARD_WINDOW_SECONDS=60
SIGIL_COMPACTOR_WORKERS=4
SIGIL_COMPACTOR_CYCLE_BUDGET=30s
SIGIL_COMPACTOR_CLAIM_TTL=5m
SIGIL_COMPACTOR_TARGET_BLOCK_BYTES=67108864
SIGIL_MODEL_CARDS_SYNC_INTERVAL=30m
SIGIL_MODEL_CARDS_LEASE_TTL=2m
SIGIL_MODEL_CARDS_SOURCE_TIMEOUT=15s
SIGIL_MODEL_CARDS_STALE_SOFT=2h
SIGIL_MODEL_CARDS_STALE_HARD=24h
SIGIL_MODEL_CARDS_BOOTSTRAP_MODE=snapshot-first

# Telemetry pipeline defaults (SDK traces + metrics -> Alloy/Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
