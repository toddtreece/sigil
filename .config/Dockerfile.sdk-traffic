FROM node:24-bookworm@sha256:3a09aa6354567619221ef6c45a5051b671f953f0a1924d1f819ffb236e520e6b

ENV PATH=$PATH:/usr/local/go/bin
ENV GOCACHE=/opt/go-cache/build
ENV GOMODCACHE=/opt/go-cache/mod
ENV GOFLAGS=-buildvcs=false
ENV NUGET_PACKAGES=/opt/nuget-cache
ENV DOTNET_CLI_HOME=/tmp/dotnet
ENV DOTNET_ROOT=/usr/share/dotnet
ENV DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
ENV DOTNET_CLI_TELEMETRY_OPTOUT=1
ENV PIP_CACHE_DIR=/opt/pip-cache
ENV GRADLE_USER_HOME=/opt/gradle-cache

COPY --from=golang:1.26-bookworm@sha256:c7a82e9e2df2fea5d8cb62a16aa6f796d2b2ed81ccad4ddd2bc9f0d22936c3f2 /usr/local/go/ /usr/local/go/
COPY --from=mcr.microsoft.com/dotnet/sdk:8.0-bookworm-slim /usr/share/dotnet/ /usr/share/dotnet/
RUN ln -sf /usr/share/dotnet/dotnet /usr/bin/dotnet \
  && dotnet --info >/dev/null

RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    openjdk-17-jdk \
    ca-certificates \
    curl \
    bash \
    git \
    protobuf-compiler \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable \
  && pnpm config set store-dir /opt/pnpm-store

WORKDIR /app/sigil

CMD ["bash", ".config/devex/sdk-traffic/run-all.sh"]
