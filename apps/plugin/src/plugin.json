{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "Sigil",
  "id": "grafana-sigil-app",
  "backend": true,
  "executable": "gpx_sigil_app",
  "info": {
    "keywords": ["app", "ai", "observability", "genai"],
    "description": "Observe what happened after you cast a prompt spell.",
    "author": {
      "name": "Grafana"
    },
    "logos": {
      "small": "img/logo.png",
      "large": "img/logo.png"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Dashboard",
      "path": "/a/grafana-sigil-app/dashboard",
      "action": "grafana-sigil-app.data:read",
      "addToNav": true,
      "defaultNav": true
    },
    {
      "type": "page",
      "name": "Conversations",
      "path": "/a/grafana-sigil-app/conversations",
      "action": "grafana-sigil-app.data:read",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Evaluation",
      "path": "/a/grafana-sigil-app/evaluation",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Conversations (old)",
      "path": "/a/grafana-sigil-app/conversations-old",
      "action": "grafana-sigil-app.data:read",
      "addToNav": false
    },
    {
      "type": "page",
      "name": "Completions",
      "path": "/a/grafana-sigil-app/completions",
      "action": "grafana-sigil-app.data:read",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Traces",
      "path": "/a/grafana-sigil-app/traces",
      "action": "grafana-sigil-app.data:read",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Settings",
      "path": "/a/grafana-sigil-app/settings",
      "action": "grafana-sigil-app.data:read",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "icon": "cog",
      "name": "Configuration",
      "path": "/plugins/grafana-sigil-app",
      "role": "Admin",
      "addToNav": true
    }
  ],
  "iam": {
    "permissions": [
      {
        "action": "datasources:read",
        "scope": "datasources:*"
      },
      {
        "action": "datasources:query",
        "scope": "datasources:*"
      },
      {
        "action": "users.permissions:read",
        "scope": "users:*"
      }
    ]
  },
  "roles": [
    {
      "grants": ["Editor", "Admin"],
      "role": {
        "name": "Sigil Reader",
        "description": "Read access to Sigil dashboards, conversations, traces, and model-card data.",
        "permissions": [
          { "action": "plugins.app:access", "scope": "plugins:id:grafana-sigil-app" },
          { "action": "grafana-sigil-app.data:read" }
        ]
      }
    },
    {
      "grants": [],
      "role": {
        "name": "Sigil Feedback Writer",
        "description": "Can write conversation feedback (ratings and annotations).",
        "permissions": [
          { "action": "plugins.app:access", "scope": "plugins:id:grafana-sigil-app" },
          { "action": "grafana-sigil-app.data:read" },
          { "action": "grafana-sigil-app.feedback:write" }
        ]
      }
    },
    {
      "grants": ["Admin"],
      "role": {
        "name": "Sigil Admin",
        "description": "Full Sigil plugin access, including feedback and datasource settings writes.",
        "permissions": [
          { "action": "plugins.app:access", "scope": "plugins:id:grafana-sigil-app" },
          { "action": "grafana-sigil-app.data:read" },
          { "action": "grafana-sigil-app.feedback:write" },
          { "action": "grafana-sigil-app.settings:write" }
        ]
      }
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.0.0-0",
    "plugins": []
  }
}
